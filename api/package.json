{
  "name": "api",
  "version": "0.0.1",
  "description": "RestApi",
  "keywords": [
    "loopback-application",
    "loopback"
  ],
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "engines": {
    "node": "20 || 22 || 24"
  },
  "scripts": {
    "build": "lb-tsc",
    "build:watch": "lb-tsc --watch",
    "lint": "pnpm run eslint && pnpm run prettier:check",
    "lint:fix": "pnpm run eslint:fix && pnpm run prettier:fix",
    "prettier:check": "prettier . --check",
    "prettier:fix": "prettier . --write",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "pretest": "pnpm run rebuild",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "docker:build": "docker build -t rest-api .",
    "docker:run": "docker run -p 3000:3000 -d rest-api",
    "premigrate": "pnpm run build",
    "migrate": "node ./dist/src/migrate",
    "preopenapi-spec": "pnpm run build",
    "openapi-spec": "node ./dist/src/openapi-spec",
    "prestart": "pnpm run rebuild",
    "start": "node -r source-map-support/register .",
    "start:prod": "db-migrate up || echo 'Migration failed, continuing...' && pnpm run start",
    "clean": "lb-clean dist *.tsbuildinfo .eslintcache",
    "rebuild": "pnpm run clean && pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "author": "Aron0228 <aronreszegi2@gmail.com>",
  "license": "",
  "files": [
    "README.md",
    "dist",
    "src",
    "!*/__tests__"
  ],
  "dependencies": {
    "@loopback/authentication": "^12.0.11",
    "@loopback/authentication-jwt": "^0.16.11",
    "@loopback/boot": "^8.0.5",
    "@loopback/core": "^7.0.4",
    "@loopback/repository": "^8.0.4",
    "@loopback/rest": "^15.0.5",
    "@loopback/rest-explorer": "^8.0.5",
    "@loopback/security": "^0.12.10",
    "@loopback/service-proxy": "^8.0.4",
    "@types/jsonapi-serializer": "^3.6.8",
    "db-migrate": "^0.11.14",
    "db-migrate-pg": "^1.5.2",
    "dotenv": "^17.3.1",
    "jsonapi-serializer": "^3.6.9",
    "loopback-connector-postgresql": "^8.0.6",
    "tslib": "^2.0.0"
  },
  "devDependencies": {
    "@loopback/build": "^12.0.4",
    "@loopback/eslint-config": "^16.0.1",
    "@loopback/testlab": "^8.0.4",
    "@types/lodash": "^4.17.23",
    "@types/node": "^16.18.126",
    "@types/pluralize": "^0.0.33",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.57.1",
    "eslint-plugin-vitest": "^0.4.1",
    "lodash": "^4.17.23",
    "moment": "^2.30.1",
    "pluralize": "^8.0.0",
    "source-map-support": "^0.5.21",
    "typescript": "~5.2.2",
    "vitest": "^4.0.18"
  }
}
